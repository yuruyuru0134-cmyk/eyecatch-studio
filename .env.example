# ── API キー ───────────────────────────────────────────────
# Claude (Anthropic) API キー — プロンプト組み立てに使用
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Gemini (Google AI Studio) API キー — 画像生成に使用
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# ── 任意設定 (未設定ならデフォルト値を使用) ──────────────────
# プロンプト組み立てプロバイダ:
#   claude … 案件要件・高品質（デフォルト, ANTHROPIC_API_KEY が必要）
#   gemini … 無料モード（Anthropicキー不要・実質0円。GEMINI_API_KEY のみで動作）
PROMPT_PROVIDER=claude

# 画像生成モデル:
#   imagen-4.0-generate-001   … 16:9/高解像度を確実に出力（推奨・有料枠の場合あり）
#   imagen-4.0-fast-generate-001 … 低コスト版
#   gemini-2.5-flash-image    … 無料枠で動作（16:9指定・省コスト）
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# 無料モード(PROMPT_PROVIDER=gemini)で使う Gemini テキストモデル
GEMINI_TEXT_MODEL=gemini-2.5-flash

# プロンプト組み立てに使う Claude モデル（PROMPT_PROVIDER=claude のときのみ使用）
ANTHROPIC_MODEL=claude-opus-4-8
